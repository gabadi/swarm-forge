#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_REPO="${SWARMFORGE_SCRIPTS_REPO:-gabadi/swarm-forge}"
MAIN_BRANCH="${SWARMFORGE_SCRIPTS_BRANCH:-main}"
RUNNABLE_BRANCH="six-pack"
ARCHIVE_URL="${SWARMFORGE_SCRIPTS_URL:-https://github.com/${SCRIPTS_REPO}/archive/refs/heads/${MAIN_BRANCH}.tar.gz}"
STATE_DIR="$SCRIPT_DIR/.swarmforge"
TMP_DIR=""

cleanup() {
  if [[ -n "$TMP_DIR" ]]; then
    rm -rf "$TMP_DIR"
  fi
}
trap cleanup EXIT

download_from_main() {
  TMP_DIR="$(mktemp -d)"
  mkdir -p "$SCRIPT_DIR/swarmforge"
  curl -fsSL "$ARCHIVE_URL" | tar -xz --strip-components=1 -C "$TMP_DIR"
  rm -rf "$SCRIPT_DIR/swarmforge/scripts"
  cp -R "$TMP_DIR/swarmforge/scripts" "$SCRIPT_DIR/swarmforge/scripts"
  rm -rf "$SCRIPT_DIR/swarmforge/skills"
  mkdir -p "$SCRIPT_DIR/swarmforge/skills"
  if [[ -d "$TMP_DIR/swarmforge/skills" ]]; then
    cp -R "$TMP_DIR/swarmforge/skills/." "$SCRIPT_DIR/swarmforge/skills/"
  fi
}

write_source_branch() {
  mkdir -p "$STATE_DIR"
  if [[ ! -f "$STATE_DIR/source-branch" ]]; then
    printf '%s\n' "$RUNNABLE_BRANCH" > "$STATE_DIR/source-branch"
  fi
}

if [[ "${1:-}" == "upgrade" ]]; then
  source_branch="$(cat "$STATE_DIR/source-branch" 2>/dev/null || echo "$RUNNABLE_BRANCH")"
  runnable_url="https://github.com/${SCRIPTS_REPO}/archive/refs/heads/${source_branch}.tar.gz"

  if ! git -C "$SCRIPT_DIR" diff --quiet -- swarmforge/ 2>/dev/null; then
    echo "Warning: swarmforge/ has local changes that will be overwritten."
    echo "Press Enter to continue or Ctrl-C to abort."
    read -r
  fi

  echo "Upgrading scripts and skills from main..."
  download_from_main

  echo "Upgrading prompts from ${source_branch}..."
  TMP_RUNNABLE="$(mktemp -d)"
  curl -fsSL "$runnable_url" | tar -xz --strip-components=1 -C "$TMP_RUNNABLE"
  for dir in roles constitution templates; do
    if [[ -d "$TMP_RUNNABLE/swarmforge/$dir" ]]; then
      rm -rf "$SCRIPT_DIR/swarmforge/$dir"
      cp -R "$TMP_RUNNABLE/swarmforge/$dir" "$SCRIPT_DIR/swarmforge/$dir"
    fi
  done
  for file in swarmforge.conf constitution.prompt; do
    if [[ -f "$TMP_RUNNABLE/swarmforge/$file" ]]; then
      cp "$TMP_RUNNABLE/swarmforge/$file" "$SCRIPT_DIR/swarmforge/$file"
    fi
  done
  rm -rf "$TMP_RUNNABLE"

  rm -f "$STATE_DIR/skills-installed"
  rm -f "$STATE_DIR/setup-complete"
  write_source_branch
  echo "Upgrade complete. Run ./swarm to start."
  exit 0
fi

if [[ ! -d "$SCRIPT_DIR/swarmforge/scripts" ]]; then
  download_from_main
fi

write_source_branch

# Preflight: scaffold project once per install (Ideas K + O)
SETUP_SENTINEL="$STATE_DIR/setup-complete"
if [[ ! -f "$SETUP_SENTINEL" ]]; then
  echo "SwarmForge: running preflight setup..."

  # Idea O: probe default branch, scaffold .gitignore, inject permission allow-rules
  DEFAULT_BRANCH="$(git -C "$SCRIPT_DIR" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || echo 'main')"

  GITIGNORE="$SCRIPT_DIR/.gitignore"
  for _entry in 'logbook.json' 'tmp/' '.swarmforge/' 'coverage.out'; do
    grep -qxF "$_entry" "$GITIGNORE" 2>/dev/null || printf '%s\n' "$_entry" >> "$GITIGNORE"
  done

  CLAUDE_SETTINGS="$SCRIPT_DIR/.claude/settings.json"
  mkdir -p "$SCRIPT_DIR/.claude"
  DEFAULT_BRANCH="$DEFAULT_BRANCH" CLAUDE_SETTINGS="$CLAUDE_SETTINGS" python3 -c '
import json, os
p = os.environ["CLAUDE_SETTINGS"]
branch = os.environ["DEFAULT_BRANCH"]
cfg = {}
try:
  with open(p) as f: cfg = json.load(f)
except: pass
allow = cfg.setdefault("permissions", {}).setdefault("allow", [])
for rule in ["Bash(gh pr merge*)", f"Bash(git reset --hard origin/{branch})"]:
  if rule not in allow:
    allow.append(rule)
with open(p, "w") as f: json.dump(cfg, f, indent=2)
  '

  # Idea K: set up entire tracing
  if command -v entire &>/dev/null; then
    (cd "$SCRIPT_DIR" && entire enable --no-github --telemetry=false) || true
    if [[ -f "$SCRIPT_DIR/swarmforge/swarmforge.conf" ]]; then
      while IFS= read -r line; do
        backend=$(echo "$line" | awk '{print $3}')
        [[ -n "$backend" ]] && (cd "$SCRIPT_DIR" && entire agent add "$backend") || true
      done < <(grep -E '^window ' "$SCRIPT_DIR/swarmforge/swarmforge.conf" | sort -k3 -u)
    fi
  else
    echo "SwarmForge: 'entire' not installed — retros will run without trace backing."
  fi

  mkdir -p "$(dirname "$SETUP_SENTINEL")"
  touch "$SETUP_SENTINEL"
  echo "SwarmForge: preflight complete."
fi

if [[ "${1:-}" == "stop" ]]; then
  shift
  exec "$SCRIPT_DIR/swarmforge/scripts/swarm-stop.sh" "$@"
fi

exec "$SCRIPT_DIR/swarmforge/scripts/swarmforge.sh" "$@"
